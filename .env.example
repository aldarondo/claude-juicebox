# ─── Network topology ───────────────────────────────────────────────────────
# NAS LAN IP — binds dnsmasq DNS/DHCP, JuicePassProxy UDP listener, and MCP port
LOCAL_IP=192.168.0.64

# JuiceBox charger IP — dnsmasq assigns this via DHCP to the charger's Wi-Fi MAC
JUICEBOX_IP=192.168.0.2

# Nirvana heat pump IP — dnsmasq assigns this via DHCP to the pump's Wi-Fi MAC
NIRVANA_IP=192.168.0.3

# LAN gateway / router IP — handed to the devices as their default gateway via DHCP
GATEWAY_IP=192.168.0.1

# ─── JuiceBox charger ───────────────────────────────────────────────────────
JUICEBOX_HOST=<YOUR-JUICEBOX-IP>
JUICEBOX_ID=JuiceBox-0E8

# First-time setup only — set to true to auto-redirect the charger's UDP traffic
# to this NAS via telnet. Set back to false after the first successful run.
# NOTE: this is unreliable on some firmware versions (see README). The DNS
# override approach (juicebox-dns container) is preferred for persistence.
UPDATE_UDPC=false

# MQTT broker auth — leave blank for anonymous (default).
# To enable auth: see mosquitto/config/mosquitto.conf for setup instructions.
MQTT_USER=
MQTT_PASS=

# MCP server port — change if 3001 is already in use on your NAS
PORT=3001

# JuicePassProxy UDP intercept port.
# Must match the port the charger's UDPC is configured to send to.
# With the DNS override approach, the charger sends to device-backend-udp-evos.juice.net:8042
# which resolves to this NAS. So LOCAL_PORT must be 8042.
LOCAL_PORT=8042

# Enel X relay — JuicePassProxy forwards intercepted packets here.
# This charger (EMWERK-JB_1_1 firmware) uses device-backend-udp-evos.juice.net:8042,
# not the legacy juicenet-udp-prod3-usa.enelx.com:8047.
ENELX_SERVER_HOST=device-backend-udp-evos.juice.net
ENELX_SERVER_PORT=8042

