# -----------------------------------------------------------------------
# JuiceBox MCP Server — environment variables
# Copy this file to .env and fill in values for your setup.
# -----------------------------------------------------------------------

# Port the HTTP/SSE server listens on inside the container (and on the host
# when running via docker-compose — both sides use the same value).
PORT=3001

# MQTT broker URL. When running via docker-compose this should point at the
# Mosquitto container. When running locally, use mqtt://localhost:1883.
MQTT_BROKER=mqtt://localhost:1883

# JuiceBox device ID — used to build the default topic names below.
# Find it on the JuiceBox display or from JuicePassProxy logs.
JUICEBOX_ID=JuiceBox-0E8

# Optional: override the MQTT topics if your JuicePassProxy version uses
# different names than the defaults (juicebox/<JUICEBOX_ID>/state and
# juicebox/<JUICEBOX_ID>/cmd).
# Tip: run  mosquitto_sub -t '#' -v  to discover the real topic names.
#MQTT_STATE_TOPIC=juicebox/JuiceBox-0E8/state
#MQTT_CMD_TOPIC=juicebox/JuiceBox-0E8/cmd

# Optional: MQTT broker credentials (leave blank if broker has no auth).
#MQTT_USER=
#MQTT_PASS=
