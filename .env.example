# JuiceBox charger
JUICEBOX_HOST=192.168.0.141
JUICEBOX_ID=JuiceBox-0E8

# First-time setup only — set to true to auto-redirect the charger's UDP traffic
# to this NAS. Set back to false after the first successful run.
UPDATE_UDPC=false

# MQTT broker auth (leave blank — anonymous is fine for local-only use)
MQTT_USER=
MQTT_PASS=

# MCP server port — change if 3001 is already in use on your NAS
MCP_PORT=3001

# Enel X relay (JuicePassProxy forwards here as a cloud fallback — leave as-is)
ENELX_SERVER_HOST=juicenet-udp-prod3-usa.enelx.com
ENELX_SERVER_PORT=8042

# Optional: override MQTT topic names if JuicePassProxy uses non-default topics.
# Leave blank to use the defaults (juicebox/{JUICEBOX_ID}/state and .../cmd).
# Run `docker exec -it juicebox-mosquitto mosquitto_sub -t '#' -v` to inspect.
MQTT_STATE_TOPIC=
MQTT_CMD_TOPIC=
